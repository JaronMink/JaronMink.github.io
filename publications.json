---
layout: null
permalink: /publications.json
---
[
{% assign sorted_publications = site.data.publications | sort: "date" | reverse %}
{% for pub in sorted_publications %}
  {
    "id": {{ pub.id | jsonify }},
    "year": {{ pub.year | jsonify }},
    "date": {{ pub.date | jsonify }},
    "title": {{ pub.title | jsonify }},
    "authors": {{ pub.authors | jsonify }},
    "venue": {{ pub.venue | jsonify }},
    "links": [
      {% for link in pub.links %}
      {% assign link_href = link.url %}
      {% if link.url_key %}
        {% assign link_href = site.data.links[link.url_key] %}
      {% endif %}
      {
        "label": {{ link.label | jsonify }},
        "style": {{ link.style | default: 'info' | jsonify }},
        "url": {{ link_href | jsonify }}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    "news": [
      {% if pub.news %}
        {% for item in pub.news %}
        {% assign item_href = item.url %}
        {% if item.url_key %}
          {% assign item_href = site.data.links[item.url_key] %}
        {% endif %}
        {
          "label": {{ item.label | jsonify }},
          "url": {{ item_href | jsonify }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      {% endif %}
    ]
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
